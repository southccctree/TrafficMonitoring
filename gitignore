# ============================================================
#  .gitignore — NetGuard
#  排除所有个人数据、编译产物、运行时生成文件
# ============================================================

# ------------------------------------------------------------
#  个人数据（流量记录，不上传）
# ------------------------------------------------------------
data/
data/daily_usage.json

# ------------------------------------------------------------
#  配置文件（含个人限额设置，不上传）
#  保留 config/netguard.json.example 作为模板
# ------------------------------------------------------------
config/netguard.json

# ------------------------------------------------------------
#  编译产物
# ------------------------------------------------------------
build/
*.exe
*.o
*.obj
*.a
*.lib
*.pdb
*.ilk
*.exp

# ------------------------------------------------------------
#  CMake 生成文件
# ------------------------------------------------------------
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
Makefile

# ------------------------------------------------------------
#  VS Code 本地配置（tasks.json 保留，其余不上传）
# ------------------------------------------------------------
.vscode/settings.json
.vscode/launch.json
.vscode/c_cpp_properties.json
.vscode/*.log

# ------------------------------------------------------------
#  第三方库（体积大，通过文档说明手动下载）
# ------------------------------------------------------------
third_party/

# ------------------------------------------------------------
#  系统文件
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
